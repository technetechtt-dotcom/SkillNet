{
  "name": "skillnet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "start:server": "tsx server/src/index.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/src/db/seed.ts",
    "db:ensure-admin": "tsx server/src/db/ensure-admin.ts",
    "db:seed-engagement": "tsx server/src/db/seed-engagement.ts",
    "db:seed-follows": "tsx server/src/db/seed-follows.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tanstack/react-query": "^5.62.8",
    "@sentry/node": "^9.5.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "framer-motion": "^11.5.4",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "0.522.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.18",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vercel/node": "^5.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "jsdom": "^25.0.1",
    "postcss": "latest",
    "supertest": "^7.0.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "vitest": "^2.1.8"
  }
}
