# Database (Neon PostgreSQL)
# Create a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/skillnet?sslmode=require

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Server (Render)
PORT=3001
NODE_ENV=production
# Your Render app URL, e.g. https://skillnet.onrender.com
CLIENT_URL=https://skillnet.onrender.com

# Frontend uses same host in production (/api and /ws) — no extra vars needed
# VITE_API_URL=/api

# Cloudinary (video/image uploads — optional)
# https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Paystack (wallet top-ups — optional)
# https://paystack.com
PAYSTACK_SECRET_KEY=

# Error monitoring (optional)
# https://sentry.io
SENTRY_DSN=

# Phone OTP (optional SMS webhook for production)
SMS_WEBHOOK_URL=
OTP_DEBUG=true
