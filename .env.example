# Database (Neon PostgreSQL)
# Create a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/skillnet?sslmode=require

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Frontend (Vercel project dashboard)
# Proxies /api/* to your Render API — set the Render base URL (no /api suffix)
# API_PROXY_URL=https://skillnet-api.onrender.com
VITE_API_URL=/api
# WebSockets must connect directly to Render
# VITE_WS_URL=wss://skillnet-api.onrender.com/ws

# Cloudinary (video/image uploads)
# https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Paystack (wallet top-ups)
# https://paystack.com
PAYSTACK_SECRET_KEY=

# Error monitoring (optional)
# https://sentry.io
SENTRY_DSN=

# Phone OTP (optional SMS webhook for production)
# POST { phone, code, purpose } JSON to your SMS provider
SMS_WEBHOOK_URL=
# Log OTP codes in production when true (dev only recommended)
OTP_DEBUG=true
