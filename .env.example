# Database (Neon PostgreSQL)
# Create a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/skillnet?sslmode=require

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Server (Render)
PORT=3001
NODE_ENV=production
# Your Render app URL, e.g. https://skillnet.onrender.com
CLIENT_URL=https://skillnet.onrender.com

# Frontend uses same host in production (/api and /ws) — no extra vars needed
# VITE_API_URL=/api

# Cloudinary (video/image uploads — optional)
# https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Paystack (wallet top-ups + withdrawals — optional)
# https://paystack.com
PAYSTACK_SECRET_KEY=
# SA transfer recipient type (default: basa)
# PAYSTACK_TRANSFER_TYPE=basa

# SMS OTP delivery (optional — falls back to console log in development)
# Africa's Talking: https://africastalking.com
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=SkillNet
# Or POST { phone, message } JSON to your own SMS provider
SMS_WEBHOOK_URL=
# Log OTP codes even in production when true (dev only recommended)
OTP_DEBUG=true

# Error monitoring (optional)
# https://sentry.io
SENTRY_DSN=
